---
import ThemeToggle from "./ThemeToggle.astro";

const { pathname } = Astro.url;
const isActive = (path: string) =>
  path === "/" ? pathname === "/" : pathname.startsWith(path);

const links = [
  { href: "/publications/", label: "Research" },
  { href: "/teaching-docencia/", label: "Teaching" },
  { href: "/blog/", label: "Blog" },
  { href: "/about/", label: "About" },
  { href: "/cv.pdf", label: "CV" },
  { href: "https://github.com/rpasquini", label: "GitHub" },
];
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/">Ricardo A. Pasquini</a>
    <nav class="main-nav" aria-label="Main">
      {links.map((l) => (
        <a href={l.href} aria-current={isActive(l.href) ? "page" : undefined}>{l.label}</a>
      ))}
      <ThemeToggle />
    </nav>
  </div>
</header>
