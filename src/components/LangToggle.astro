---
interface Props {
  targetId: string;
}

const { targetId } = Astro.props;
---
<div class="lang-toggle" role="group" aria-label="Language">
  <button type="button" class="lang-btn" data-lang-btn="en" aria-pressed="true">English</button>
  <button type="button" class="lang-btn" data-lang-btn="es" aria-pressed="false">Español</button>
</div>

<script is:inline define:vars={{ targetId }}>
  (function () {
    var wrap = document.getElementById(targetId);
    if (!wrap) return;

    function apply(lang) {
      wrap.setAttribute("data-lang", lang);
      wrap.querySelectorAll("[data-lang-content]").forEach(function (el) {
        el.hidden = el.getAttribute("data-lang-content") !== lang;
      });
      wrap.querySelectorAll("[data-lang-btn]").forEach(function (btn) {
        btn.setAttribute("aria-pressed", String(btn.getAttribute("data-lang-btn") === lang));
      });
    }

    var stored = localStorage.getItem("about-lang");
    if (stored) apply(stored);

    wrap.querySelectorAll("[data-lang-btn]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var lang = btn.getAttribute("data-lang-btn");
        localStorage.setItem("about-lang", lang);
        apply(lang);
      });
    });
  })();
</script>
