<div class="filter-bar">
  <input type="search" id="pagefind-search-input" placeholder="Search posts…" aria-label="Search posts" />
</div>
<ul class="post-list" id="pagefind-results"></ul>

<script>
  const input = document.getElementById("pagefind-search-input") as HTMLInputElement | null;
  const results = document.getElementById("pagefind-results") as HTMLUListElement | null;
  const postList = document.querySelector<HTMLElement>(".post-list:not(#pagefind-results)");

  let pagefind: { search: (q: string) => Promise<{ results: { data: () => Promise<any> }[] }> } | null = null;

  async function ensurePagefind() {
    if (pagefind) return pagefind;
    try {
      // @ts-ignore — only exists in the built output, generated by the postbuild pagefind step
      pagefind = await import(/* @vite-ignore */ "/pagefind/pagefind.js");
    } catch {
      pagefind = null;
    }
    return pagefind;
  }

  input?.addEventListener("input", async () => {
    const query = input.value.trim();
    if (!results) return;
    if (!query) {
      results.innerHTML = "";
      if (postList) postList.style.display = "";
      return;
    }
    const pf = await ensurePagefind();
    if (!pf) return;
    if (postList) postList.style.display = "none";

    const search = await pf.search(query);
    const items = await Promise.all(search.results.slice(0, 15).map((r) => r.data()));
    results.innerHTML = items
      .map(
        (item: any) =>
          `<li><h3><a href="${item.url}">${item.meta?.title ?? item.url}</a></h3><p class="excerpt">${item.excerpt}</p></li>`
      )
      .join("");
  });
</script>
